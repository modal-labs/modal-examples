# Use the Parseable base URL without /v1/logs, /v1/traces, or /v1/metrics.
PARSEABLE_ENDPOINT=https://parseable.example.com
PARSEABLE_API_KEY=REPLACE_WITH_PARSEABLE_INGESTION_API_KEY
PARSEABLE_LOGS_STREAM=modal-logs
PARSEABLE_TRACES_STREAM=modal-traces
PARSEABLE_METRICS_STREAM=modal-metrics
OTLP_INGEST_TOKEN=REPLACE_WITH_A_LONG_RANDOM_TOKEN
